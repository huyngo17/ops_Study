@{
    ViewData["Title"] = "Log Written";
    var timestamp = ViewBag.Timestamp as DateTimeOffset? ?? DateTimeOffset.UtcNow;
}

<div class="py-5 text-center">
    <div class="mb-3">
        <span class="display-1 text-primary"><i class="bi bi-journal-check"></i></span>
    </div>
    <h1 class="display-6 fw-bold">Log Entry Written</h1>
    <p class="lead text-secondary">An <code>Information</code>-level log was emitted via <code>ILogger</code>.</p>

    <div class="card bg-body-secondary border-secondary mx-auto mb-4 text-start" style="max-width:560px;">
        <div class="card-header border-secondary d-flex align-items-center gap-2 py-2">
            <i class="bi bi-terminal text-success"></i>
            <span class="small text-muted">Log entry</span>
            <span class="ms-auto badge bg-success bg-opacity-10 text-success border border-success border-opacity-25">Information</span>
        </div>
        <div class="card-body py-3">
            <code class="text-success small">
                [@timestamp.ToString("yyyy-MM-dd HH:mm:ss") UTC] Manual log endpoint called
            </code>
        </div>
    </div>

    <div class="card bg-body-secondary border-secondary mx-auto mb-4 text-start" style="max-width:560px;">
        <div class="card-body small text-secondary py-3">
            <p class="mb-1 fw-semibold text-light">View logs in Docker:</p>
            <code class="text-warning">docker logs &lt;container-name&gt;</code>
            <hr class="border-secondary my-2" />
            <p class="mb-1 fw-semibold text-light">Follow live:</p>
            <code class="text-warning">docker logs -f &lt;container-name&gt;</code>
        </div>
    </div>

    <a class="btn btn-outline-secondary me-2" asp-controller="Home" asp-action="Log">
        <i class="bi bi-arrow-repeat me-1"></i>Write again
    </a>
    <a class="btn btn-primary" asp-controller="Home" asp-action="Index">
        <i class="bi bi-arrow-left me-1"></i>Back home
    </a>
</div>

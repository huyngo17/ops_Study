@model ErrorViewModel

@{
    ViewData["Title"] = "Error — OpsStudy";
}

<div class="py-5 text-center">
    <div class="mb-3">
        <span class="display-1 text-danger"><i class="bi bi-exclamation-triangle-fill"></i></span>
    </div>
    <h1 class="display-6 fw-bold text-danger">Exception Caught</h1>
    <p class="lead text-secondary">The global exception handler intercepted a demo error.</p>

    @if (Model.ShowRequestId)
    {
        <div class="d-inline-flex align-items-center gap-2 bg-body-secondary border border-secondary rounded px-3 py-2 mb-4">
            <span class="text-muted small">Request ID</span>
            <code class="text-warning">@Model.RequestId</code>
        </div>
    }

    <div class="card bg-body-secondary border-danger border-opacity-50 mx-auto mb-4" style="max-width:520px;">
        <div class="card-body text-start small text-secondary">
            <p class="mb-1"><i class="bi bi-info-circle me-2 text-info"></i>This exception was intentional — thrown by <code>/Home/Boom</code>.</p>
            <p class="mb-1"><i class="bi bi-journal-text me-2 text-primary"></i>An <code>Error</code>-level log entry has been written via <code>ILogger</code>.</p>
            <p class="mb-0"><i class="bi bi-terminal me-2 text-success"></i>View it with <code>docker logs &lt;container-name&gt;</code>.</p>
        </div>
    </div>

    <a class="btn btn-primary" asp-controller="Home" asp-action="Index">
        <i class="bi bi-arrow-left me-1"></i>Back home
    </a>
</div>

@{
    ViewData["Title"] = "OpsStudy — Container Lab";
}

<div class="py-4">
    @* Hero *@
    <div class="text-center mb-5">
        <div class="mb-3">
            <span class="display-1 text-success"><i class="bi bi-terminal-fill"></i></span>
        </div>
        <h1 class="display-5 fw-bold">OpsStudy Lab</h1>
        <p class="lead text-secondary mx-auto" style="max-width:520px;">
            A minimal ASP.NET Core MVC app for practising container deployments, log pipelines, and exception handling.
        </p>
        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2">
            <i class="bi bi-circle-fill me-1" style="font-size:.5rem;vertical-align:middle;"></i> Running
        </span>
    </div>

    @* Action cards *@
    <div class="row g-3 justify-content-center mb-5">

        <div class="col-12 col-md-4">
            <div class="card bg-body-secondary border-secondary h-100">
                <div class="card-body d-flex flex-column p-4">
                    <div class="mb-3">
                        <span class="fs-2 text-primary"><i class="bi bi-journal-text"></i></span>
                    </div>
                    <h5 class="card-title fw-semibold">Write Log</h5>
                    <p class="card-text text-secondary small flex-grow-1">
                        Emits an <code>Information</code> log entry via <code>ILogger</code>. Check output with
                        <code>docker logs &lt;container&gt;</code>.
                    </p>
                    <a class="btn btn-primary mt-3" asp-controller="Home" asp-action="Log">
                        <i class="bi bi-play-fill me-1"></i>Write log
                    </a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card bg-body-secondary border-secondary h-100">
                <div class="card-body d-flex flex-column p-4">
                    <div class="mb-3">
                        <span class="fs-2 text-danger"><i class="bi bi-bug-fill"></i></span>
                    </div>
                    <h5 class="card-title fw-semibold">Throw Error</h5>
                    <p class="card-text text-secondary small flex-grow-1">
                        Throws an <code>InvalidOperationException</code> to test the global exception handler and
                        <code>Error</code> log output.
                    </p>
                    <a class="btn btn-outline-danger mt-3" asp-controller="Home" asp-action="Boom">
                        <i class="bi bi-lightning-fill me-1"></i>Throw demo error
                    </a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card bg-body-secondary border-secondary h-100">
                <div class="card-body d-flex flex-column p-4">
                    <div class="mb-3">
                        <span class="fs-2 text-success"><i class="bi bi-heart-pulse-fill"></i></span>
                    </div>
                    <h5 class="card-title fw-semibold">Health Check</h5>
                    <p class="card-text text-secondary small flex-grow-1">
                        Returns a JSON health payload at <code>/health</code>. Useful as a Docker / Kubernetes liveness probe target.
                    </p>
                    <a class="btn btn-outline-success mt-3" href="/health" target="_blank">
                        <i class="bi bi-activity me-1"></i>Health check
                    </a>
                </div>
            </div>
        </div>

    </div>

    @* Info strip *@
    <div class="card bg-body-secondary border-secondary">
        <div class="card-body py-3">
            <div class="row text-center text-secondary small g-2">
                <div class="col-6 col-md-3">
                    <i class="bi bi-box-seam me-1"></i>ASP.NET Core MVC
                </div>
                <div class="col-6 col-md-3">
                    <i class="bi bi-cpu me-1"></i>.NET 10
                </div>
                <div class="col-6 col-md-3">
                    <i class="bi bi-box me-1"></i>Container ready
                </div>
                <div class="col-6 col-md-3">
                    <i class="bi bi-file-earmark-text me-1"></i>Structured logging
                </div>
            </div>
        </div>
    </div>
</div>

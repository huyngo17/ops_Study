@{
    ViewData["Title"] = "TerraformLP MVC Demo";
}

<div class="text-center py-5">
    <h1 class="display-5">TerraformLP MVC Demo</h1>
    <p class="lead">A tiny ASP.NET Core MVC app for container deployment practice.</p>

    <div class="d-flex gap-2 justify-content-center flex-wrap mt-4">
        <a class="btn btn-primary" asp-controller="Home" asp-action="Log">Write log</a>
        <a class="btn btn-outline-danger" asp-controller="Home" asp-action="Boom">Throw demo error</a>
        <a class="btn btn-outline-secondary" href="/health">Health check</a>
    </div>
</div>
